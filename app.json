{
  "expo": {
    "name": "Combustíveis",
    "slug": "combustiveis",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "combustiveis",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F0F4F8"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.combustiveis.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "A app Combustíveis precisa da sua localização para encontrar os postos de combustível mais próximos."
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F0F4F8"
      },
      "package": "com.combustiveis.app",
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "A app Combustíveis precisa da sua localização para encontrar os postos de combustível mais próximos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
